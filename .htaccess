Options -Indexes

# Block direct access to sensitive directories
<FilesMatch "\.(env|sql|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Clean URLs — route non-file, non-directory requests through index.php
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /PTE-MANAGEMENT-SYSTEM/

    # Allow direct access to real files and directories (assets, vendor, etc.)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else to index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
